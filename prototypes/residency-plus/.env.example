SOUNDCLOUD_CLIENT_ID=YOUR_CLIENT_ID
SOUNDCLOUD_CLIENT_SECRET=YOUR_CLIENT_SECRET
ALLOWED_ORIGINS=http://localhost:8888,http://localhost:3000

# Optional: Telemetry Forwarding
AXIOM_API_TOKEN=YOUR_AXIOM_API_TOKEN
AXIOM_DATASET=YOUR_DATASET_NAME
AXIOM_DOMAIN=us-east-1.aws.edge.axiom.co

# Auth + Persistence (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Local Dev Resilience ───────────────────────────────────────────────────────
# Fast-failover: bypasses SoundCloud entirely and returns realistic local 
# fixtures. Perfect for UI work when offline or throttled.
# DEV_FIXTURE_MODE=true

# When SoundCloud rate limits your local token requests (HTTP 429), enable this
# to proxy local searches directly through the production wrapper.
# DEV_USE_PROD_WRAPPER_FALLBACK=true
# DEV_PROD_WRAPPER_BASE=https://residencysolutions.netlify.app

# Optional: Manually inject a known-good token into the local /tmp cache to
# avoid requesting new tokens on boot entirely. Never commit an actual token.
# SOUNDCLOUD_BOOTSTRAP_ACCESS_TOKEN=your-temporary-token
